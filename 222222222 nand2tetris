💻 2. CÓDIGO COMPLETO (LO QUE NECESITAS)

👉 ESTE ES EL QUE DEBES SABER / ENTENDER

CHIP ALU {
    IN  
        x[16], y[16],
        zx, nx, zy, ny, f, no;
    OUT 
        out[16],
        zr,
        ng;

    PARTS:
    // zx: if 1 → x = 0
    Mux16(a=x, b=false, sel=zx, out=x1);

    // nx: if 1 → x = !x
    Not16(in=x1, out=notx);
    Mux16(a=x1, b=notx, sel=nx, out=x2);

    // zy: if 1 → y = 0
    Mux16(a=y, b=false, sel=zy, out=y1);

    // ny: if 1 → y = !y
    Not16(in=y1, out=noty);
    Mux16(a=y1, b=noty, sel=ny, out=y2);

    // f: 1 = suma, 0 = AND
    Add16(a=x2, b=y2, out=addxy);
    And16(a=x2, b=y2, out=andxy);
    Mux16(a=andxy, b=addxy, sel=f, out=out1);

    // no: negar salida
    Not16(in=out1, out=notout);
    Mux16(a=out1, b=notout, sel=no, out=out);

    // zr: out == 0
    Or16Way(in=out, out=orOut);
    Not(in=orOut, out=zr);

    // ng: out < 0 → bit más significativo
    // (bit 15)
    // si es 1 → negativo
    ng = out[15];
}
